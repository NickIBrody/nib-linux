#!/bin/sh

R="\033[1;31m"
G="\033[1;32m"
Y="\033[1;33m"
N="\033[0m"

echo -e "${G}======================================"
echo -e "     NIB Linux Installer v0.1"
echo -e "======================================${N}"

echo -e "\n${Y}Available disks:${N}"
fdisk -l 2>/dev/null | grep "^Disk /dev/" | grep -v loop
echo ""

echo -e "${R}WARNING: This will erase the selected disk!${N}"
printf "Enter target disk (e.g. /dev/sda): "
read DISK

if [ ! -b "$DISK" ]; then
    echo "Error: $DISK not found."
    exit 1
fi

printf "Are you sure? All data on $DISK will be lost! (yes/no): "
read CONFIRM
[ "$CONFIRM" != "yes" ] && echo "Aborted." && exit 0

echo -e "\n${Y}Partitioning $DISK...${N}"
printf "o\nn\np\n1\n\n\na\nw\n" | fdisk "$DISK"
sleep 1

PART="${DISK}1"
echo -e "${Y}Formatting ${PART}...${N}"
mkfs.ext4 -F "$PART"

echo -e "${Y}Mounting...${N}"
mkdir -p /mnt/nib
mount "$PART" /mnt/nib

echo -e "${Y}Copying rootfs...${N}"
cp -a / /mnt/nib/ 2>/dev/null
mkdir -p /mnt/nib/proc /mnt/nib/sys /mnt/nib/dev /mnt/nib/tmp

echo -e "${Y}Installing GRUB...${N}"
grub-install --root-directory=/mnt/nib "$DISK"

cat > /mnt/nib/boot/grub/grub.cfg << GRUBEOF
set default=0
set timeout=3
menuentry "NIB Linux" {
    linux /boot/vmlinuz root=${PART} quiet
    initrd /boot/initrd.img
}
GRUBEOF

echo -e "${Y}Copying kernel...${N}"
cp /boot/vmlinuz /mnt/nib/boot/ 2>/dev/null
cp /boot/initrd.img /mnt/nib/boot/ 2>/dev/null

umount /mnt/nib

echo -e "\n${G}Installation complete!${N}"
echo -e "Remove the ISO and reboot."
