#!/bin/sh
set -u

export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

CMDLINE="$(cat /proc/cmdline 2>/dev/null)"
NIB_DEBUG=0
NIB_RESCUE=0
case " $CMDLINE " in
    *" nib.debug=1 "*) NIB_DEBUG=1 ;;
esac
case " $CMDLINE " in
    *" nib.rescue=1 "*) NIB_RESCUE=1 ;;
esac

panic_shell() {
    echo
    echo "[nib-init] boot failed, dropping to shell"
    exec /bin/sh -i </dev/console >/dev/console 2>&1
}

log() {
    echo "[nib-init] $*"
}

mount -t devtmpfs devtmpfs /dev 2>/dev/null || mkdir -p /dev
exec </dev/console >/dev/console 2>&1

mount -t proc proc /proc 2>/dev/null || panic_shell
mount -t sysfs sysfs /sys 2>/dev/null || panic_shell
mount -t tmpfs tmpfs /tmp 2>/dev/null || panic_shell
mount -t tmpfs tmpfs /run 2>/dev/null || panic_shell
mkdir -p /dev/pts /run/wpa_supplicant /var/run /lib/firmware /lib/modules /mnt
mount -t devpts devpts /dev/pts 2>/dev/null || true

log "cmdline: $CMDLINE"
log "mounting early filesystems"

if command -v mdev >/dev/null 2>&1; then
    if [ -e /proc/sys/kernel/hotplug ]; then
        echo /bin/mdev > /proc/sys/kernel/hotplug 2>/dev/null || true
    fi
    mdev -s 2>/dev/null || true
fi

ROOT_FS="$(awk '$2=="/" {print $3; exit}' /proc/mounts 2>/dev/null)"
case "$ROOT_FS" in
    rootfs|tmpfs|ramfs) LIVE=1 ;;
    *) LIVE=0 ;;
esac

log "root filesystem: ${ROOT_FS:-unknown}"
if [ "$LIVE" = "1" ]; then
    log "mode: live installer"
else
    log "mode: installed system"
fi

if [ "$NIB_RESCUE" = "1" ]; then
    log "rescue mode requested"
    exec /bin/sh -i </dev/console >/dev/console 2>&1
fi

WIRED_UP=0
if [ "$LIVE" = "1" ]; then
    for iface in $(ls /sys/class/net/ 2>/dev/null | grep -E '^(eth|en|em|eno|enp|ens)'); do
        log "bringing up $iface"
        ip link set "$iface" up 2>/dev/null || true
        if udhcpc -i "$iface" -n -q -t 2 -T 2 -s /usr/share/udhcpc/default.script 2>/dev/null; then
            WIRED_UP=1
            break
        fi
    done

    echo "nameserver 8.8.8.8" > /etc/resolv.conf
    echo "nameserver 1.1.1.1" >> /etc/resolv.conf
else
    mount -o remount,rw / 2>/dev/null || true
    mount -a 2>/dev/null || true
fi

echo
echo "Forge Linux v1.0"
echo

if [ "$LIVE" = "1" ]; then
    echo "Mode: live installer"
    echo "Commands:"
    echo "  wifi-connect <SSID> [pass]   connect to WiFi"
    echo "  wifi-connect --scan          scan networks"
    echo "  start-installer              launch installer"
    echo "  ns install <pkg>             install package"
    echo

    if [ "$WIRED_UP" = "1" ]; then
        echo "Network: connected (wired)"
    else
        echo "Network: not connected -- run wifi-connect"
    fi
else
    echo "Mode: installed system"
    echo "Commands:"
    echo "  ns install <pkg>             install package"
fi

echo
if [ "$NIB_DEBUG" = "1" ]; then
    echo "Block devices:"
    ls /dev/sd* /dev/nvme* /dev/vd* 2>/dev/null || true
    echo
    echo "Network devices:"
    ls /sys/class/net 2>/dev/null || true
    echo
fi

if [ "$LIVE" = "1" ]; then
    log "starting live autologin consoles on tty2-tty4"
    for tty in 2 3 4; do
        setsid /sbin/getty -n -l /usr/local/bin/live-login-root -L 115200 "tty$tty" vt100 </dev/null >/dev/null 2>&1 &
    done
    exec /bin/sh -i </dev/console >/dev/console 2>&1
else
    log "starting virtual consoles on tty1-tty4"
    for tty in 2 3 4; do
        setsid /sbin/getty -L 115200 "tty$tty" vt100 </dev/null >/dev/null 2>&1 &
    done
    exec setsid /sbin/getty -L 115200 tty1 vt100
fi
