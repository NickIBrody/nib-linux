#!/bin/sh
mount -t devtmpfs devtmpfs /dev
mount -t proc proc /proc
mount -t sysfs sysfs /sys

mkdir -p /tmp

ip link set eth0 up
udhcpc -i eth0 -q -s /usr/share/udhcpc/default.script
echo "nameserver 8.8.8.8" > /etc/resolv.conf

clear
echo
echo "======================================"
echo "      WELCOME TO NIB LINUX"
echo "    The monster is officially ALIVE"
echo "======================================"
echo

exec setsid cttyhack /bin/sh
