#!/bin/sh

export TERM=linux
TMPDIR=/tmp/nib-install
mkdir -p $TMPDIR

die() {
    dialog --title "Error" --msgbox "\n$1" 8 50
    clear
    exit 1
}

cleanup() {
    umount /mnt/nibroot/boot/efi 2>/dev/null || true
    umount /mnt/nibroot 2>/dev/null || true
    rm -rf $TMPDIR
}
trap cleanup EXIT

if [ "$(id -u)" != "0" ]; then
    dialog --title "NIB Linux Installer" --msgbox "\nThis installer must be run as root." 7 45
    clear
    exit 1
fi

dialog --title "NIB Linux Installer" \
    --backtitle "NIB Linux 1.0" \
    --yesno "\nWelcome to the NIB Linux installer.\n\nThis will install NIB Linux to a disk on this machine.\n\nAll data on the selected disk will be ERASED.\n\nContinue?" \
    13 55
[ $? -eq 0 ] || { clear; exit 0; }

DISK_LIST=""
for dev in $(lsblk -d -n -o NAME,TYPE 2>/dev/null | awk '$2=="disk"{print $1}'); do
    SIZE=$(lsblk -d -n -o SIZE "/dev/$dev" 2>/dev/null)
    MODEL=$(lsblk -d -n -o MODEL "/dev/$dev" 2>/dev/null | sed 's/[[:space:]]*$//')
    [ -z "$MODEL" ] && MODEL="Unknown"
    DISK_LIST="$DISK_LIST $dev \"$SIZE  $MODEL\""
done

if [ -z "$DISK_LIST" ]; then
    die "No disks found on this system."
fi

DISK=$(eval dialog \
    --title \"Select Target Disk\" \
    --backtitle \"NIB Linux 1.0\" \
    --menu \"\nChoose the disk to install NIB Linux on.\nAll data will be erased.\" \
    16 60 6 \
    $DISK_LIST \
    3>&1 1>&2 2>&3)

[ $? -eq 0 ] || { clear; exit 0; }
[ -z "$DISK" ] && { clear; exit 0; }

DISK_SIZE=$(lsblk -d -n -o SIZE "/dev/$DISK" 2>/dev/null)
DISK_MODEL=$(lsblk -d -n -o MODEL "/dev/$DISK" 2>/dev/null | sed 's/[[:space:]]*$//')

dialog --title "Confirm Installation" \
    --backtitle "NIB Linux 1.0" \
    --defaultno \
    --yesno "\n  Disk:   /dev/$DISK\n  Size:   $DISK_SIZE\n  Model:  $DISK_MODEL\n\n  WARNING: ALL DATA WILL BE PERMANENTLY ERASED.\n\nAre you sure you want to continue?" \
    13 55
[ $? -eq 0 ] || { clear; exit 0; }

if echo "$DISK" | grep -q "nvme"; then
    EFI_PART="/dev/${DISK}p1"
    ROOT_PART="/dev/${DISK}p2"
else
    EFI_PART="/dev/${DISK}1"
    ROOT_PART="/dev/${DISK}2"
fi

STEPS=7
step() {
    STEP_N=$1
    STEP_MSG=$2
    PCT=$(( STEP_N * 100 / STEPS ))
    echo "$PCT"
    echo "XXX"
    echo "$PCT%  —  $STEP_MSG"
    echo "XXX"
}

(
step 1 "Partitioning disk..."
sfdisk "/dev/$DISK" > /dev/null 2>&1 << 'SFDISK_END'
label: gpt
start=2048,   size=1048576, type=C12A7328-F81F-11D2-BA4B-00A0C93EC93B, name="EFI"
start=1050624,              type=0FC63DAF-8483-4772-8E79-3D69D8477DE4, name="NIBLinux"
SFDISK_END
sleep 1
partprobe "/dev/$DISK" 2>/dev/null || true
sleep 1

step 2 "Formatting EFI partition..."
mkfs.fat -F32 -n "NIBEFI" "$EFI_PART" > /dev/null 2>&1

step 3 "Formatting root partition..."
mkfs.ext4 -L "NIBLinux" -F "$ROOT_PART" > /dev/null 2>&1

step 4 "Mounting partitions..."
mkdir -p /mnt/nibroot
mount "$ROOT_PART" /mnt/nibroot
mkdir -p /mnt/nibroot/boot/efi
mount "$EFI_PART" /mnt/nibroot/boot/efi

step 5 "Extracting system files..."
mkdir -p /mnt/iso
ISO_DEV=""
for dev in /dev/sr0 /dev/sr1 /dev/cdrom /dev/dvd; do
    if mount -o ro "$dev" /mnt/iso 2>/dev/null; then
        ISO_DEV="$dev"
        break
    fi
done
if [ -z "$ISO_DEV" ]; then
    echo "ERROR: Cannot find/mount installation ISO" > $TMPDIR/error
    umount /mnt/iso 2>/dev/null; rmdir /mnt/iso 2>/dev/null
    echo "100"; exit 1
fi
if [ ! -f /mnt/iso/boot/rootfs.tar.gz ]; then
    echo "ERROR: rootfs.tar.gz not found on ISO" > $TMPDIR/error
    umount /mnt/iso 2>/dev/null; rmdir /mnt/iso 2>/dev/null
    echo "100"; exit 1
fi
tar -xzf /mnt/iso/boot/rootfs.tar.gz -C /mnt/nibroot 2>/dev/null
VMLINUZ_SRC=/mnt/iso/boot/vmlinuz
umount /mnt/iso 2>/dev/null
rmdir /mnt/iso 2>/dev/null

step 6 "Installing bootloader..."
mkdir -p /mnt/nibroot/boot/grub

ROOT_UUID=$(blkid -s UUID -o value "$ROOT_PART")
EFI_UUID=$(blkid -s UUID -o value "$EFI_PART")

cp "$VMLINUZ_SRC" /mnt/nibroot/boot/vmlinuz 2>/dev/null || true

cat > /mnt/nibroot/boot/grub/grub.cfg << GRUBEOF
set default=0
set timeout=3

insmod part_gpt
insmod part_msdos
insmod fat
insmod ext2
insmod linux
insmod all_video

terminal_input console
terminal_output console

menuentry "NIB Linux" {
    search --no-floppy --fs-uuid --set=root $ROOT_UUID
    linux /boot/vmlinuz root=UUID=$ROOT_UUID rw quiet console=tty0
}

menuentry "NIB Linux (nomodeset)" {
    search --no-floppy --fs-uuid --set=root $ROOT_UUID
    linux /boot/vmlinuz root=UUID=$ROOT_UUID rw quiet nomodeset console=tty0
}

menuentry "NIB Linux (recovery)" {
    search --no-floppy --fs-uuid --set=root $ROOT_UUID
    linux /boot/vmlinuz root=UUID=$ROOT_UUID rw console=tty0 init=/bin/sh
}
GRUBEOF

cat > /mnt/nibroot/etc/fstab << FSTABEOF
UUID=$ROOT_UUID  /         ext4  defaults,noatime  0 1
UUID=$EFI_UUID   /boot/efi vfat  defaults          0 2
tmpfs            /tmp      tmpfs defaults,nosuid    0 0
FSTABEOF

grub-install --target=x86_64-efi \
    --efi-directory=/mnt/nibroot/boot/efi \
    --boot-directory=/mnt/nibroot/boot \
    --removable "/dev/$DISK" > /dev/null 2>&1 || true

grub-install --target=i386-pc \
    --boot-directory=/mnt/nibroot/boot \
    "/dev/$DISK" > /dev/null 2>&1 || true

step 7 "Finalizing..."
rm -f /mnt/nibroot/usr/local/bin/nib-install /mnt/nibroot/bin/nib-install 2>/dev/null || true
sync
umount /mnt/nibroot/boot/efi 2>/dev/null || true
umount /mnt/nibroot 2>/dev/null || true
echo "100"

) | dialog \
    --title "Installing NIB Linux" \
    --backtitle "NIB Linux 1.0" \
    --gauge "\nInstalling NIB Linux to /dev/$DISK...\n" \
    10 55 0

if [ -f $TMPDIR/error ]; then
    die "$(cat $TMPDIR/error)"
fi

dialog --title "Installation Complete" \
    --backtitle "NIB Linux 1.0" \
    --msgbox "\nNIB Linux has been successfully installed to /dev/$DISK.\n\nRemove the installation media and reboot to start your new system." \
    11 55

clear
